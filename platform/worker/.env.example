# Copy to .env and fill values. .env is gitignored — never commit real credentials.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB=stokebroker
DATA_CACHE=./data
LOG_LEVEL=INFO

# account defaults for trade-number forecasts
ACCOUNT_SIZE=500000
RISK_PCT=1.0
